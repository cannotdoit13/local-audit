# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/locality_audit

# OpenAI (for news classification)
OPENAI_API_KEY=sk-your-key-here

# MapTiler (free vector tiles - get key at https://cloud.maptiler.com/account/keys/)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key-here

# Redis
REDIS_URL=redis://localhost:6379

# SerpAPI (for Google Maps reviews scraping)
SERPAPI_KEY=your-key-here

# Reddit API (optional - works without, but higher rate limits with)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter/X API (optional - falls back to Nitter scraping)
TWITTER_BEARER_TOKEN=

# Razorpay (for premium payments)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-secret-here
